 1049 | // NOTE: These wrappers intentionally do *not* cache the resolved config path at
 1050 | // module scope. `ANIMA_CONFIG_PATH` (and friends) are expected to work even
 1051 | // when set after the module has been imported (tests, one-off scripts, etc.).
 1052 | const DEFAULT_CONFIG_CACHE_MS = 200;
 1053 | let configCache: {
 1054 |   configPath: string;
 1055 |   expiresAt: number;
 1056 |   config: AnimaConfig;
 1057 | } | null = null;
 1058 | 
 1059 | function resolveConfigCacheMs(env: NodeJS.ProcessEnv): number {
 1060 |   const raw = env.ANIMA_CONFIG_CACHE_MS?.trim();
 1061 |   if (raw === "" || raw === "0") {
 1062 |     return 0;
 1063 |   }
 1064 |   if (!raw) {
 1065 |     return DEFAULT_CONFIG_CACHE_MS;
 1066 |   }
 1067 |   const parsed = Number.parseInt(raw, 10);
 1068 |   if (!Number.isFinite(parsed)) {
 1069 |     return DEFAULT_CONFIG_CACHE_MS;
 1070 |   }
 1071 |   return Math.max(0, parsed);
 1072 | }
 1073 | 
 1074 | function shouldUseConfigCache(env: NodeJS.ProcessEnv): boolean {
 1075 |   if (env.ANIMA_DISABLE_CONFIG_CACHE?.trim()) {
 1076 |     return false;
 1077 |   }
 1078 |   return resolveConfigCacheMs(env) > 0;
 1079 | }
 1080 | 
 1081 | export function clearConfigCache(): void {
 1082 |   configCache = null;
 1083 | }
 1084 | 
 1085 | export function loadConfig(): AnimaConfig {
 1086 |   const io = createConfigIO();
 1087 |   const configPath = io.configPath;
 1088 |   const now = Date.now();
 1089 |   if (shouldUseConfigCache(process.env)) {
 1090 |     const cached = configCache;
 1091 |     if (cached && cached.configPath === configPath && cached.expiresAt > now) {
 1092 |       return cached.config;
 1093 |     }
 1094 |   }
 1095 |   const config = io.loadConfig();
 1096 |   if (shouldUseConfigCache(process.env)) {
 1097 |     const cacheMs = resolveConfigCacheMs(process.env);
 1098 |     if (cacheMs > 0) {
 1099 |       configCache = {
 1100 |         configPath,
 1101 |         expiresAt: now + cacheMs,
 1102 |         config,
 1103 |       };
 1104 |     }
 1105 |   }
 1106 |   return config;
 1107 | }
